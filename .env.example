# fal.ai API key — SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.
# Get one at https://fal.ai/dashboard/keys — rotate any key that was ever in client code.
FAL_KEY=

# Hard ceiling on paid try-on generations per day across ALL users (cache hits
# are free and don't count). Platform-wide money circuit-breaker on top of each
# shop's own plan allowance. Protects the fal balance from abuse. Default: 500.
TRYON_DAILY_CAP=500

# Comma-separated extra hostnames allowed to call the spend/write API routes
# (/api/tryon, /api/lead). The deployment's own host is always allowed; set this
# for any additional domains (custom domain + www). Cross-site browser calls
# from anywhere else are rejected. Example: peeq.app,www.peeq.app
ALLOWED_ORIGINS=

# Public site origin used to build payment return/callback URLs. Falls back to
# the request host if unset — set it in production so gateway redirects land
# on the right domain. Example: https://peeq.app
NEXT_PUBLIC_SITE_URL=

# ── Plan payments (Khalti + eSewa) ──────────────────────────────────────────
# Defaults below are SANDBOX. Swap in live credentials + live *_BASE to go live.
# Khalti ePayment: get a secret key at https://khalti.com (merchant dashboard).
KHALTI_SECRET_KEY=
KHALTI_BASE=https://a.khalti.com                 # live: https://khalti.com
# eSewa ePay v2. UAT defaults work out of the box for testing.
ESEWA_PRODUCT_CODE=EPAYTEST                       # live: your merchant code
ESEWA_SECRET=8gBm/:&EnhH.1/q(                     # live: your merchant secret
ESEWA_BASE=https://rc-epay.esewa.com.np           # live: https://epay.esewa.com.np
ESEWA_STATUS_BASE=https://rc.esewa.com.np         # live: https://epay.esewa.com.np

# Supabase — leave blank to run in local mode (localStorage, no auth, per-browser).
# Set all three to enable auth, shared DB, image storage, persistent cache/rate limits
# and cross-device /k/[shop] links. Run supabase/schema.sql in the SQL editor first.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER-SIDE ONLY (used by /api/tryon for cache + rate limits + analytics).
SUPABASE_SERVICE_ROLE_KEY=

# Demo-store seeder (npm run seed) — all optional, defaults shown.
# Put photos in images/ (see images/README.md) before running.
# SEED_EMAIL=demo@easyfitcheck.app
# SEED_PASSWORD=easyfit-demo
# SEED_SHOP_SLUG=demo-store
