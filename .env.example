# fal.ai API key — SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.
# Get one at https://fal.ai/dashboard/keys — rotate any key that was ever in client code.
FAL_KEY=

# Hard ceiling on paid try-on generations per day across ALL users (cache hits
# are free and don't count). Protects the fal balance from abuse. Default: 500.
TRYON_DAILY_CAP=500

# Supabase — leave blank to run in local mode (localStorage, no auth, per-browser).
# Set all three to enable auth, shared DB, image storage, persistent cache/rate limits
# and cross-device /k/[shop] links. Run supabase/schema.sql in the SQL editor first.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER-SIDE ONLY (used by /api/tryon for cache + rate limits + analytics).
SUPABASE_SERVICE_ROLE_KEY=

# Demo-store seeder (npm run seed) — all optional, defaults shown.
# Put photos in images/ (see images/README.md) before running.
# SEED_EMAIL=demo@easyfitcheck.app
# SEED_PASSWORD=easyfit-demo
# SEED_SHOP_SLUG=demo-store
