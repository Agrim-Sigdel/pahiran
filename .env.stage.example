# STAGING — template for the `stage` branch env set.
# Copy to .env.stage.local, fill in the blanks, then upload to Vercel scoped to
# Preview + branch `stage`. Bootstrap procedure: docs/environments.md
#
# This file is COMMITTED — never put real secret values in it.
#
# Vars deliberately omitted because the code default is already correct for
# staging: ESEWA_PRODUCT_CODE / ESEWA_SECRET / ESEWA_BASE / ESEWA_STATUS_BASE
# all default to the eSewa UAT sandbox in src/lib/billing.ts. Setting them here
# would only duplicate those defaults — and ESEWA_SECRET contains an "&", which
# is easy to mangle when importing a .env file.

# ── Supabase: the `pahiran-stage` project, NOT production ───────────────────
# Project Settings → API. Run supabase/schema.sql then
# supabase/migrations/20260720000100_shopper_accounts.sql before pointing at it.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI providers ────────────────────────────────────────────────────────────
# Prefer a staging-only key from https://fal.ai/dashboard/keys — sharing
# production's key means staging try-ons bill the same balance.
FAL_KEY=
# Optional. Powers "studio" quality; without it studio silently falls back to
# quick (src/app/api/tryon/route.ts).
OPEN_AI_API_KEY=
# Platform-wide ceiling on paid generations per day. Real money if the fal key
# is shared with production — keep it well under the production cap.
TRYON_DAILY_CAP=200

# ── Host-dependent ──────────────────────────────────────────────────────────
# Builds payment return/callback URLs and storefront metadata.
NEXT_PUBLIC_SITE_URL=https://stage.peeq.fashion
# "*" disables the cross-site guard on /api/tryon and /api/lead entirely — any
# website can spend try-on credits and post into vendor lead inboxes. Acceptable
# on staging, NEVER in production. Tighten to "*.vercel.app,stage.peeq.fashion"
# if you'd rather keep the guard on for preview URLs only.
ALLOWED_ORIGINS=*

# ── Checkout channels ───────────────────────────────────────────────────────
NEXT_PUBLIC_CHECKOUT_WHATSAPP=1
NEXT_PUBLIC_CHECKOUT_LEADS=1

# ── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAILS=siliconpeaksvc@gmail.com

# ── Payments (sandbox) ──────────────────────────────────────────────────────
# Khalti sandbox secret from the merchant dashboard. Left blank, Khalti checkout
# returns 401 on staging; eSewa still works off its UAT defaults.
KHALTI_SECRET_KEY=
KHALTI_BASE=https://a.khalti.com
